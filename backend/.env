# Server Monitor Configuration
DATABASE_URL=postgres://postgres:your-password@localhost:5432/svrmonitor?sslmode=require
JWT_SECRET=change-me-to-a-random-string
SERVER_PORT=8080

# Encryption key for SSH credentials at rest (32 bytes, generate with: openssl rand -hex 16)
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# TLS (optional - leave empty to use HTTP)
TLS_CERT_FILE=
TLS_KEY_FILE=

# CORS
CORS_ORIGIN=http://localhost:5173
